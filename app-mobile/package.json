{
  "name": "cantine-connecte",
  "version": "1.0.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "copy:assets": "node -e \"const fs = require('fs'); const path = require('path'); const src = './assets'; const dest = './public'; if (!fs.existsSync(dest)) fs.mkdirSync(dest); fs.readdirSync(src).forEach(file => fs.copyFileSync(path.join(src, file), path.join(dest, file)))\"",
    "start": "expo start",
    "start:clear": "expo start -c",
    "start:docker": "expo start --web --host 0.0.0.0 --port 8081 --clear",
    "start:web": "SKIP_PREFLIGHT_CHECK=true expo start --web --clear",
    "build:web": "npm run copy:assets && expo export --platform web",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "eslint ."
  },
  "dependencies": {
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/metro-runtime": "~3.2.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "^6.6.1",
    "@react-navigation/native": "^6.1.18",
    "@react-navigation/native-stack": "^6.11.0",
    "@supabase/supabase-js": "^2.105.1",
    "expo": "^49.0.23",
    "expo-font": "~12.0.10",
    "expo-image-picker": "^15.0.7",
    "expo-status-bar": "~1.12.1",
    "lucide-react-native": "^1.14.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.72.10",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "react-native-svg": "^15.15.4",
    "react-native-web": "~0.19.6"
  },
  "devDependencies": {
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^8.57.0",
    "eslint-config-universe": "^13.0.0"
  }
}
