# =====================================================
# Cantine Connecte - Environment Template (Expo)
# =====================================================
# Rules:
# 1) Copy this file to .env (do not commit .env)
# 2) Keep EXPO_PUBLIC_ prefix for variables used in client code
# 3) Never put service_role keys in mobile env files

# -----------------------------------------------------
# Required - Supabase (client safe values only)
# -----------------------------------------------------
# Format: https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon/public key from Supabase Project Settings > API
# Example starts with: eyJ...
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------
# Optional - App metadata
# -----------------------------------------------------
# Allowed values: dev | staging | prod
EXPO_PUBLIC_APP_ENV=dev

# API timeout in milliseconds (numeric only)
EXPO_PUBLIC_API_TIMEOUT_MS=15000

# -----------------------------------------------------
# Optional - Expo CLI stability flags
# -----------------------------------------------------
# Disable API cache and doctor checks when Expo CLI fails with
# "Cannot read properties of undefined (reading 'bodyStream')"
EXPO_NO_CACHE=1
EXPO_NO_DOCTOR=1
